datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-1.1.x"]
  previewFeatures = ["tracing"]
}

model Activity {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  text      String
  // Used to link the task or activity to external apps
  sourceURL String?

  integrationAccount   IntegrationAccount? @relation(fields: [integrationAccountId], references: [id], onDelete: Cascade)
  integrationAccountId String?

  rejectionReason String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  WebhookDeliveryLog WebhookDeliveryLog[]

  ConversationHistory ConversationHistory[]
  IngestionQueue      IngestionQueue[]
}

model AuthorizationCode {
  id String @id @default(cuid())

  code String @unique

  personalAccessToken   PersonalAccessToken? @relation(fields: [personalAccessTokenId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  personalAccessTokenId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agents {
  id String @id @default(cuid())

  name String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BillingHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Billing period
  periodStart DateTime
  periodEnd   DateTime

  // Credits tracking
  monthlyCreditsAllocated Int
  creditsUsed             Int
  overageCreditsUsed      Int

  // Charges
  subscriptionAmount Float
  usageAmount        Float // Overage charges
  totalAmount        Float

  // Stripe integration
  stripeInvoiceId     String? @unique
  stripePaymentStatus String?

  // Relations
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId String
}

model Conversation {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  unread    Boolean @default(false)
  source    String  @default("core")
  incognito Boolean @default(false)

  asyncJobId String?

  title  String?
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String?

  status         String  @default("pending") // Can be "pending", "running", "completed", "failed", "need_attention"
  activeStreamId String? // Set while background stream is active; cleared on completion

  ConversationHistory ConversationHistory[]
  knowledgeCaptureBatches KnowledgeCaptureBatch[]
  RecallLog           RecallLog[]
  codingSessions      CodingSession[]
}

model CompactedSessionEmbedding {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vector   Unsupported("vector")
  summary  String
  metadata Json?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@map("compacted_session_embeddings")
}

model ConversationHistory {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  message  String //Deprecated
  parts    Json?
  userType UserType

  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String?

  context Json?

  thoughts Json?
  user     User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
}

enum KnowledgeCaptureBatchStatus {
  PROPOSED
  ARCHIVED
}

enum KnowledgeCaptureItemKind {
  ENTITY
  RELATION
  EVENT
  DECISION
}

enum KnowledgeCaptureItemStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  SNOOZED
  MERGED
}

enum RejectReason {
  INACCURATE
  IRRELEVANT
  DUPLICATE
  TRIVIAL
  OTHER
}

model KnowledgeCaptureBatch {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  sessionId String
  summary   String
  status    KnowledgeCaptureBatchStatus @default(PROPOSED)

  sourceEpisodeUuids String[] @default([])

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  items KnowledgeCaptureItem[]

  @@index([userId, workspaceId, createdAt(sort: Desc)])
  @@index([conversationId])
  @@index([sessionId])
}

model KnowledgeCaptureItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batchId String
  batch   KnowledgeCaptureBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  kind       KnowledgeCaptureItemKind
  title      String
  payload    Json
  evidence   Json?
  confidence Float?
  importance Float?

  firstSeenAt    DateTime
  lastSeenAt     DateTime
  lastReviewedAt DateTime?
  status         KnowledgeCaptureItemStatus @default(PROPOSED)

  acceptedGraphUuid String?
  mergeTargetUuid   String?

  rejectReason RejectReason?
  reviewNotes  String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([batchId, status])
  @@index([userId, workspaceId, status, updatedAt(sort: Desc)])
  @@index([kind, status])
  @@index([acceptedGraphUuid])
}

model Document {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  sessionId String?

  title       String
  content     String
  labelIds    String[]
  source      String
  metadata    Json?
  type        String
  version     Int      @default(1)
  contentHash String?
  chunkHashes String[]

  editedBy    String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([sessionId, workspaceId])
  @@index([workspaceId])
  @@index([sessionId, workspaceId])
}

model EntityEmbedding {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  vector   Unsupported("vector")
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@map("entity_embeddings")
}

model LabelEmbedding {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?
  vector      Unsupported("vector")
  metadata    Json?

  workspaceId String

  @@index([workspaceId])
  @@map("label_embeddings")
}

model EpisodeEmbedding {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content         String
  vector          Unsupported("vector")
  labelIds        String[]
  metadata        Json?
  sessionId       String
  originalContent String?
  chunkIndex      Int?
  chunkHash       String?
  version         Int?

  ingestionQueueId String
  ingestionQueue   IngestionQueue @relation(fields: [ingestionQueueId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([userId, workspaceId, labelIds])
  @@index([userId, workspaceId, sessionId])
  @@index([userId, workspaceId, sessionId, version])
  @@map("episode_embeddings")
}

model IngestionQueue {
  id String @id @default(cuid())

  // Queue metadata
  data     Json // The actual data to be processed
  output   Json? // The processed output data
  status   IngestionStatus
  priority Int             @default(0)

  source    String?
  title     String?
  sessionId String?

  type String?

  // Graph and organization
  graphIds  String[] @default([]) // Array of Neo4j graph node IDs
  labels    String[] @default([]) // Array of label IDs this episode belongs to
  favourite Boolean  @default(false) // Whether this episode is marked as favourite

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String?

  // Error handling
  error      String?
  retryCount Int     @default(0)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?

  episodeEmbeddings EpisodeEmbedding[]

  @@index([workspaceId, sessionId])
  @@index([workspaceId, sessionId, createdAt(sort: Desc)])
}

model IngestionRule {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  name     String? // Optional human-readable rule name
  text     String // Free-flowing text rule description (mandatory)
  source   String // Source/integration this rule applies to (mandatory)
  isActive Boolean @default(true) // Enable/disable rule (mandatory)

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
}

model IntegrationAccount {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  integrationConfiguration Json
  accountId                String?
  settings                 Json?
  isActive                 Boolean @default(true)

  integratedBy            User                    @relation(references: [id], fields: [integratedById], onDelete: Cascade)
  integratedById          String
  integrationDefinition   IntegrationDefinitionV2 @relation(references: [id], fields: [integrationDefinitionId], onDelete: Cascade)
  integrationDefinitionId String
  workspace               Workspace               @relation(references: [id], fields: [workspaceId], onDelete: Cascade)
  workspaceId             String
  Activity                Activity[]
  oauthIntegrationGrants  OAuthIntegrationGrant[]
  IntegrationCallLog      IntegrationCallLog[]

  @@unique([accountId, integrationDefinitionId, workspaceId])
}

model IntegrationDefinitionV2 {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  name        String  @unique
  slug        String
  description String
  icon        String
  config      Json?
  spec        Json    @default("{}")
  version     String?
  url         String?

  frontendUrl String?

  workspace   Workspace? @relation(references: [id], fields: [workspaceId], onDelete: Cascade)
  workspaceId String?

  IntegrationAccount IntegrationAccount[]
}

model InvitationCode {
  id   String @id @default(cuid())
  code String @unique

  identifier String? // email or phone number for agent invites
  source     String? // 'whatsapp' or 'email' for agent invites
  expiresAt  DateTime? // expiry for agent invites

  // Workspace invitation support
  workspaceId String? // If set, this invitation is for a specific workspace
  role        WorkspaceRole? // Role to assign when user accepts workspace invite

  UserWorkspace UserWorkspace[]

  createdAt DateTime @default(now())
}

model Label {
  id          String  @id @default(cuid())
  name        String
  description String?

  color String

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MCPSession {
  id           String   @id @default(cuid())
  source       String
  integrations String[]

  workspace   Workspace? @relation(references: [id], fields: [workspaceId], onDelete: Cascade)
  workspaceId String?

  createdAt DateTime  @default(now())
  deleted   DateTime?
}

model Gateway {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name        String
  description String?

  // Supported tools - stored as JSON array of { name, description, inputSchema? }
  tools Json @default("{}")

  // Connection status
  status         GatewayStatus @default(DISCONNECTED)
  lastSeenAt     DateTime?
  connectedAt    DateTime?
  disconnectedAt DateTime?

  // Client metadata
  clientVersion String?
  platform      String? // "darwin", "linux", "win32"
  hostname      String?

  // Relations
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([workspaceId, name])
  @@index([workspaceId, status])

  codingSessions CodingSession[]
}

enum GatewayStatus {
  CONNECTED
  DISCONNECTED
}

model OAuthAuthorizationCode {
  id String @id @default(cuid())

  code String @unique

  // OAuth2 specific fields
  clientId            String
  userId              String
  redirectUri         String
  scope               String?
  state               String?
  codeChallenge       String?
  codeChallengeMethod String?
  expiresAt           DateTime
  used                Boolean  @default(false)

  // Relations
  client      OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OAuthAccessToken {
  id String @id @default(cuid())

  token     String   @unique
  clientId  String
  userId    String
  scope     String?
  expiresAt DateTime
  revoked   Boolean  @default(false)

  // Relations
  client      OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OAuthClient {
  id String @id @default(cuid())

  clientId     String  @unique
  clientSecret String
  name         String
  description  String?

  // Redirect URIs (comma-separated for simplicity)
  redirectUris String

  // Allowed scopes (comma-separated)
  allowedScopes String @default("read")

  // Grant types allowed
  grantTypes String @default("authorization_code")

  // PKCE support
  requirePkce Boolean @default(false)

  clientType String @default("regular")

  // Client metadata
  logoUrl     String?
  homepageUrl String?

  // Integration hub webhook support
  webhookUrl    String?
  webhookSecret String?

  // GitHub-style features
  isActive Boolean @default(true)

  // Workspace relationship (like GitHub orgs)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String?

  // Created by user (for audit trail)
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdById String?

  // Relations
  oauthAuthorizationCodes OAuthAuthorizationCode[]
  accessTokens            OAuthAccessToken[]
  refreshTokens           OAuthRefreshToken[]
  integrationGrants       OAuthIntegrationGrant[]
  oAuthClientInstallation OAuthClientInstallation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OAuthClientInstallation {
  id String @id @default(cuid())

  // The OAuth client being installed
  oauthClient   OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  oauthClientId String

  // The workspace where it's installed
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  // Installation metadata
  installedBy   User      @relation(fields: [installedById], references: [id], onDelete: Cascade)
  installedById String
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?

  // Installation status
  isActive Boolean @default(true)

  // Installation-specific settings
  settings Json?

  grantedScopes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([oauthClientId, workspaceId])
}

model OAuthRefreshToken {
  id String @id @default(cuid())

  token     String   @unique
  clientId  String
  userId    String
  scope     String?
  expiresAt DateTime
  revoked   Boolean  @default(false)

  // Relations
  client      OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OAuthIntegrationGrant {
  id String @id @default(cuid())

  // OAuth client that has access
  client   OAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  // User who granted access
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  // Integration account that was granted
  integrationAccount   IntegrationAccount @relation(fields: [integrationAccountId], references: [id], onDelete: Cascade)
  integrationAccountId String

  // When access was granted/revoked
  grantedAt DateTime  @default(now())
  revokedAt DateTime?
  isActive  Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, userId, integrationAccountId])
}

model PersonalAccessToken {
  id String @id @default(cuid())

  /// If generated by the CLI this will be "cli", otherwise user-provided
  name String

  /// This is the token encrypted using the ENCRYPTION_KEY
  encryptedToken Json

  /// This is shown in the UI, with ********
  obfuscatedToken String

  /// This is used to find the token in the database
  hashedToken String @unique

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String?

  revokedAt      DateTime?
  lastAccessedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorizationCodes AuthorizationCode[]
}

model IntegrationCallLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Integration account information
  integrationAccount   IntegrationAccount @relation(fields: [integrationAccountId], references: [id], onDelete: Cascade)
  integrationAccountId String

  // Tool/action information
  toolName String // The tool that was called (e.g., "gmail_send_email")

  // Source tracking
  source String? // Source of the call (e.g., "Claude-Code", "Cursor", "mcp", "api")

  // Error tracking
  error String? // Error message if the call failed
}

model RecallLog {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  // Access details
  accessType String // "search", "recall", "direct_access"
  query      String? // Search query (null for direct access)

  // Target information
  targetType String? // "episode", "statement", "entity", "mixed_results"
  targetId   String? // UUID of specific target (null for search with multiple results)

  // Search/access parameters
  searchMethod  String? // "semantic", "keyword", "hybrid", "contextual", "graph_traversal"
  minSimilarity Float? // Minimum similarity threshold used
  maxResults    Int? // Maximum results requested

  // Results and interaction
  resultCount     Int    @default(0) // Number of results returned
  similarityScore Float? // Similarity score (for single result access)

  // Context and source
  context   String? // Additional context
  source    String? // Source of the access (e.g., "chat", "api", "integration")
  sessionId String? // Session identifier

  // Performance metrics
  responseTimeMs Int? // Response time in milliseconds

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String?

  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String?

  // Metadata for additional tracking data
  metadata Json? @default("{}")
}

model Channel {
  id          String     @id @default(uuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  type        String // "slack" | "telegram" | "whatsapp" | "email"
  config      Json // type-specific: Slack: { bot_token, user_token?, channel_id?, team_id?, team_name? } Telegram: { bot_token, chat_id, username? }
  isDefault   Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  reminders   Reminder[]
  tasks       Task[]

  @@index([workspaceId])
  @@index([workspaceId, type])
}

model Reminder {
  id               String    @id @default(uuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  text             String // Action text - can include goal context (e.g., "drink water (goal: 3L daily)")
  schedule         String // RRule string (e.g., "FREQ=DAILY;BYHOUR=9" or "FREQ=MINUTELY;INTERVAL=15")
  startDate        DateTime? // Don't fire before this date (for "tomorrow at X" reminders)
  nextRunAt        DateTime? // Next scheduled run time (computed from rrule)
  maxOccurrences   Int? // null = unlimited, 1 = one-time, N = limited
  occurrenceCount  Int       @default(0) // Auto-deactivate when >= maxOccurrences
  endDate          DateTime? // Optional: auto-deactivate after this date
  channel          String    @default("whatsapp") // "whatsapp" or "email" — kept for backward compat
  channelId        String? // FK to Channel table (optional, new explicit routing)
  channelRef       Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  isActive         Boolean   @default(true)
  confirmedActive  Boolean   @default(false) // User said "yes" to keep - never ask again
  unrespondedCount Int       @default(0)
  lastSentAt       DateTime?
  metadata         Json? // Flexible tracking: { followUpSentAt, lastAcknowledgedAt, skipCount, etc. }
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([workspaceId])
  @@index([isActive])
  @@index([nextRunAt])
}

model StatementEmbedding {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fact     String
  vector   Unsupported("vector")
  labelIds String[]
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([userId, workspaceId, labelIds])
  @@map("statement_embeddings")
}

model VoiceAspect {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fact         String // Complete statement as user expressed it
  aspect       String // Directive | Preference | Habit | Belief | Goal
  episodeUuids String[] // All episode UUIDs that mention/reinforce this aspect

  validAt       DateTime  @default(now())
  invalidAt     DateTime?
  invalidatedBy String? // Episode UUID that invalidated this

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([userId, aspect])
  @@index([userId, workspaceId, aspect])
  @@index([invalidAt])
  @@map("voice_aspects")
}

model VoiceAspectEmbedding {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fact     String
  aspect   String // Directive | Preference | Habit | Belief | Goal
  vector   Unsupported("vector")
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId])
  @@index([userId, workspaceId, aspect])
  @@map("voice_aspect_embeddings")
}

model Subscription {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Stripe integration
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Plan details
  planType PlanType           @default(FREE)
  status   SubscriptionStatus @default(ACTIVE)

  // Monthly credits allocation
  monthlyCredits Int @default(0)

  // Billing cycle tracking
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime

  // Usage-based pricing (for PRO plan)
  enableUsageBilling  Boolean @default(false)
  usagePricePerCredit Float? // Price per credit after monthly quota

  // Overage tracking
  overageCreditsUsed Int   @default(0)
  overageAmount      Float @default(0)

  // Relations
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId    String           @unique
  BillingHistory BillingHistory[]
}

model User {
  id    String @id @default(cuid())
  email String @unique

  authenticationMethod      AuthenticationMethod
  authenticationProfile     Json?
  authenticationExtraParams Json?
  authIdentifier            String?              @unique

  displayName String?
  name        String?
  avatarUrl   String?

  memoryFilter String? // Adding memory filter instructions

  // Folder structure for organizing favorites (episodes/sessions)
  folders Json? @default("{\"folders\": []}")

  admin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketingEmails       Boolean @default(true)
  confirmedBasicDetails Boolean @default(false)
  onboardingComplete    Boolean @default(false)

  referralSource String?

  metadata Json @default("{}")

  // WhatsApp agent authentication
  phoneNumber String? @unique

  personalAccessTokens PersonalAccessToken[]
  UserWorkspace        UserWorkspace[]
  IntegrationAccount   IntegrationAccount[]
  WebhookConfiguration WebhookConfiguration[]
  Conversation         Conversation[]
  ConversationHistory  ConversationHistory[]
  IngestionRule        IngestionRule[]

  // OAuth2 relations
  oauthAuthorizationCodes   OAuthAuthorizationCode[]
  oauthAccessTokens         OAuthAccessToken[]
  oauthRefreshTokens        OAuthRefreshToken[]
  oauthClientsCreated       OAuthClient[]
  oauthIntegrationGrants    OAuthIntegrationGrant[]
  oAuthClientInstallation   OAuthClientInstallation[]
  UserUsage                 UserUsage?
  RecallLog                 RecallLog[]
  StatementEmbedding        StatementEmbedding[]
  EpisodeEmbedding          EpisodeEmbedding[]
  EntityEmbedding           EntityEmbedding[]
  CompactedSessionEmbedding CompactedSessionEmbedding[]
  Gateway                   Gateway[]
  VoiceAspect               VoiceAspect[]
  VoiceAspectEmbedding      VoiceAspectEmbedding[]
  knowledgeCaptureBatches   KnowledgeCaptureBatch[]
  knowledgeCaptureItems     KnowledgeCaptureItem[]
}

model UserUsage {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  // Current period tracking
  availableCredits Int @default(0)
  usedCredits      Int @default(0)
  overageCredits   Int @default(0) // Credits used beyond monthly allocation

  // Last reset tracking
  lastResetAt DateTime  @default(now())
  nextResetAt DateTime?

  // Usage breakdown (optional analytics)
  episodeCreditsUsed Int @default(0)
  searchCreditsUsed  Int @default(0)
  chatCreditsUsed    Int @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique
}

model UserWorkspace {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // User-Workspace relationship
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  // Role and permissions
  role WorkspaceRole @default(MEMBER)

  // Invitation and acceptance tracking
  invitedBy        String? // User ID who invited this user
  invitationCode   InvitationCode? @relation(fields: [invitationCodeId], references: [id], onDelete: SetNull)
  invitationCodeId String?
  invitedAt        DateTime        @default(now())
  acceptedAt       DateTime?
  isActive         Boolean         @default(true)

  // User preferences for this workspace
  settings Json? @default("{}")

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@index([workspaceId, role])
}

model WebhookConfiguration {
  id          String     @id @default(cuid())
  url         String
  secret      String?
  isActive    Boolean    @default(true)
  eventTypes  String[] // List of event types this webhook is interested in, e.g. ["activity.created"]
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  WebhookDeliveryLog WebhookDeliveryLog[]
}

model WebhookDeliveryLog {
  id                     String               @id @default(cuid())
  webhookConfiguration   WebhookConfiguration @relation(fields: [webhookConfigurationId], references: [id], onDelete: Cascade)
  webhookConfigurationId String

  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  activityId String?

  status             WebhookDeliveryStatus
  responseStatusCode Int?
  responseBody       String?
  error              String?
  deliveredAt        DateTime              @default(now())

  createdAt DateTime @default(now())
}

model Workspace {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  name String
  slug String  @unique
  icon String?

  version  WorkspaceVersion @default(V3)
  metadata Json             @default("{}")

  // Plain-text PAT used exclusively by remotely loaded widgets.
  // Never returned to the UI. Created once and reused.
  widgetPat String?

  // deprecated but keep until we move them
  userId String? @unique

  integrations String[]

  UserWorkspace           UserWorkspace[]
  IngestionQueue          IngestionQueue[]
  IntegrationAccount      IntegrationAccount[]
  IntegrationDefinitionV2 IntegrationDefinitionV2[]
  Activity                Activity[]
  WebhookConfiguration    WebhookConfiguration[]
  Conversation            Conversation[]
  IngestionRule           IngestionRule[]
  OAuthClient             OAuthClient[]
  OAuthClientInstallation OAuthClientInstallation[]
  OAuthAuthorizationCode  OAuthAuthorizationCode[]
  OAuthAccessToken        OAuthAccessToken[]
  OAuthRefreshToken       OAuthRefreshToken[]
  RecallLog               RecallLog[]
  Label                   Label[]
  MCPSession              MCPSession[]
  Subscription            Subscription?
  documents               Document[]
  personalAccessTokens    PersonalAccessToken[]
  statementEmbeddings     StatementEmbedding[]
  episodeEmbeddings       EpisodeEmbedding[]
  entityEmbeddings        EntityEmbedding[]
  gateways                Gateway[]
  reminders               Reminder[]
  channels                Channel[]
  tasks                   Task[]
  pages                   Page[]
  butlerComments          ButlerComment[]
  voiceAspects            VoiceAspect[]
  voiceAspectEmbeddings   VoiceAspectEmbedding[]
  llmProviders            LLMProvider[]
  codingSessions          CodingSession[]
  knowledgeCaptureBatches KnowledgeCaptureBatch[]
  knowledgeCaptureItems   KnowledgeCaptureItem[]
  wikiEntries             WikiEntry[]
}

enum TaskStatus {
  Todo
  Waiting
  Ready
  Working
  Review
  Done
  Recurring
}

model Task {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String?
  status      TaskStatus @default(Todo)

  conversationIds String[]

  result String?
  error  String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  userId      String

  jobId    String?
  metadata Json?   @default("{}")

  // Scheduling fields (unified with reminders)
  schedule         String? // RRule string for recurring (null = one-time or immediate)
  nextRunAt        DateTime? // When to fire next (one-time scheduled or recurring)
  lastRunAt        DateTime?
  occurrenceCount  Int       @default(0)
  maxOccurrences   Int? // null = unlimited, 1 = one-shot
  isActive         Boolean   @default(true)
  startDate        DateTime? // Don't fire before this date
  endDate          DateTime? // Auto-deactivate after this date
  confirmedActive  Boolean   @default(false)
  unrespondedCount Int       @default(0)

  channel    String? // Delivery channel name/type
  channelId  String? // FK to Channel table
  channelRef Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  parentTaskId String? // FK to self (subtasks/follow-ups)
  parentTask   Task?   @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks     Task[]  @relation("TaskSubtasks")

  displayId String? // Hierarchical human-readable ID e.g. tk-abcde, tk-abcde.1.2

  pageId String? @unique
  page   Page?   @relation("TaskPage", fields: [pageId], references: [id], onDelete: SetNull)
  source String  @default("manual")

  codingSessions CodingSession[]


  @@unique([workspaceId, displayId])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([userId, status])
  @@index([nextRunAt])
  @@index([isActive])
  @@index([parentTaskId])
  @@index([workspaceId, isActive, nextRunAt])
}

enum PageType {
  Daily
  Task
}

model Page {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deleted   DateTime?

  type              PageType  @default(Daily)
  date              DateTime?
  description       String?
  descriptionBinary Bytes?
  butlerLastSeen    Bytes?
  outlinks          Json?     @default("[]")

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String

  task   Task? @relation("TaskPage")
  butlerComments ButlerComment[]

  @@unique([workspaceId, userId, date])
  @@index([workspaceId, userId])
}

model ButlerComment {
  id         String    @id @default(uuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolved   Boolean   @default(false)
  resolvedAt DateTime?

  selectedText   String
  content        String
  relativeStart  Json?
  relativeEnd    Json?

  pageId         String
  conversationId String?
  workspaceId    String

  page      Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([pageId, resolved])
}

enum PlanType {
  FREE
  PRO
  MAX
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  PAUSED
}

enum AuthenticationMethod {
  GOOGLE
  MAGIC_LINK
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  NO_CREDITS
}

enum UserType {
  Agent
  User
  System
}

enum WebhookDeliveryStatus {
  SUCCESS
  FAILED
}

enum WorkspaceVersion {
  V1
  V2
  V3
}

enum WorkspaceRole {
  OWNER // Full control, can delete workspace, manage billing
  ADMIN // Can manage users, settings, integrations
  MEMBER // Can access and use workspace features
  GUEST // Limited read-only access
}

// ---------------------------------------------------------------------------
// LLM Providers & Models
// ---------------------------------------------------------------------------

model LLMProvider {
  id          String     @id @default(uuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String // "OpenAI", "Anthropic", "Google", "Ollama"
  type        String // "openai", "anthropic", "google", "ollama"
  config      Json       @default("{}")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  models      LLMModel[]

  @@index([workspaceId])
  @@index([type])
}

model LLMModel {
  id            String      @id @default(uuid())
  providerId    String
  provider      LLMProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelId       String // "gpt-5-2025-08-07"
  label         String // "GPT-5"
  complexity    String // "high", "medium", "low"
  supportsBatch Boolean     @default(true)
  isEnabled     Boolean     @default(true)
  isDeprecated  Boolean     @default(false)
  capabilities  String[] // ["chat", "structured", "reasoning"] or ["embedding"]
  dimensions    Int? // For embedding models (e.g., 1024, 1536, 3072)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([providerId])
  @@index([complexity])
}

// ---------------------------------------------------------------------------
// Coding Sessions
// ---------------------------------------------------------------------------

model CodingSession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  externalSessionId String?
  agent             String
  prompt            String?
  dir               String?
  worktreePath      String?
  worktreeBranch    String?

  task           Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId         String?

  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  conversationId String?

  gateway   Gateway? @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  gatewayId String?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
  userId      String

  @@index([taskId])
  @@index([workspaceId])
  @@index([conversationId])
  @@index([gatewayId])
}

// ---------------------------------------------------------------------------
// Wiki Entries
// ---------------------------------------------------------------------------

enum WikiEntryStatus {
  DRAFT
  PUBLISHED
  REJECTED
}

model WikiEntry {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entityUuid String // Reference to EntityNode in Neo4j
  title      String // Entry title, usually the entity name
  definition String // Brief definition, 1-2 sentences
  summary    String // Summary, 3-5 sentences
  content    String // Detailed explanation in Markdown format

  status     WikiEntryStatus @default(DRAFT)
  reviewedAt DateTime?

  rejectReason RejectReason?
  reviewNotes  String?

  userId      String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  versions WikiEntryVersion[]

  @@index([userId, workspaceId])
  @@index([entityUuid])
  @@unique([entityUuid, workspaceId])
}

model WikiEntryVersion {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  wikiEntryId String
  wikiEntry   WikiEntry @relation(fields: [wikiEntryId], references: [id], onDelete: Cascade)

  version    Int // Version number, starting from 1
  title      String
  definition String
  summary    String
  content    String

  sourceEpisodeUuid String? // Episode UUID that triggered this update

  @@index([wikiEntryId, version])
}
