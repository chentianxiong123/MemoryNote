VERSION=0.7.3

# Local development. If running inside Docker, change DB_HOST to postgres.
DB_HOST=localhost
DB_PORT=5432

# POSTGRES
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=memorynote

LOGIN_ORIGIN=http://localhost:3033
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}?schema=memorynote

# This sets the URL used for direct connections to the database and should only be needed in limited circumstances
# See: https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#fields:~:text=the%20shadow%20database.-,directUrl,-No
DIRECT_URL=${DATABASE_URL}

REMIX_APP_PORT=3033
APP_ENV=production
NODE_ENV=${APP_ENV}
APP_ORIGIN=http://localhost:3033
API_BASE_URL=${APP_ORIGIN}


SESSION_SECRET=
ENCRYPTION_KEY=

########### Sign.in with google ############
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

ENABLE_EMAIL_LOGIN=true

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_MODE=responses
GOOGLE_GENERATIVE_AI_API_KEY=

MAGIC_LINK_SECRET=
NEO4J_AUTH=neo4j/<your-neo4j-password>
OLLAMA_URL=http://ollama:11434

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_SIZE=1536
EMBEDDING_API_KEY=
MODEL=gpt-5.2-2025-12-11

# Provider routing (optional)
CHAT_PROVIDER=openai
# EMBEDDINGS_PROVIDER=openai
# Override tolerant JSON parsing behavior (optional). Controls error tolerance when parsing LLM responses
# Set to 'true' to allow lenient parsing, or leave empty for strict mode: true/1/yes or false/0/no
LLM_TOLERANT_OUTPUT=

########### Reranking Configuration ############
# Choose reranking provider: 'cohere', 'ollama', 'openai', or 'none'
# - 'cohere': Use Cohere API for high-quality reranking (requires COHERE_API_KEY)
# - 'ollama': Use local Ollama model for reranking (requires OLLAMA_URL and a rerank model)
# - 'openai': Use OpenAI-compatible rerank API (requires RERANK_API_KEY and RERANK_BASE_URL)
# - 'none': No reranking, use original search algorithm scores
RERANK_PROVIDER=none

# Cohere settings (when RERANK_PROVIDER=cohere)
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0
COHERE_SCORE_THRESHOLD=0.3

# Ollama settings (when RERANK_PROVIDER=ollama)
# Model examples: qwen2.5:14b-rerank, bge-reranker-v2-m3
OLLAMA_RERANK_MODEL=dengcao/Qwen3-Reranker-8B:Q5_K_M
OLLAMA_SCORE_THRESHOLD=0.3

# OpenAI-compatible rerank API (when RERANK_PROVIDER=openai)
# Supports any OpenAI-compatible rerank endpoint (e.g., qwen3-reranker)
RERANK_API_KEY=
RERANK_BASE_URL=https://api.openai.com/v1
RERANK_MODEL=qwen3-reranker-8b
RERANK_SCORE_THRESHOLD=0.3

## AWS Bedrock ##
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# Email (Resend)
# EMAIL_TRANSPORT=resend
# RESEND_API_KEY=
FROM_EMAIL=
